{
  "name": "dlp-master",
  "version": "1.0.0",
  "description": "Desktop video downloader powered by yt-dlp.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thienhash-coder/dlp-master.git"
  },
  "keywords": [],
  "author": "thienhash-coder",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/thienhash-coder/dlp-master/issues"
  },
  "homepage": "https://github.com/thienhash-coder/dlp-master#readme",
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.thienhashcoder.dlpmaster",
    "productName": "DLP Master",
    "files": [
      "main.js",
      "index.html",
      "FastAPI - main.py",
      "fastapi-main.py",
      "public.key",
      "bundle/**",
      "yt_dlp/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "thienhash-coder",
        "repo": "dlp-master",
        "releaseType": "release"
      }
    ]
  }
}
